# syntax=docker/dockerfile:1

# Immagine di SVILUPPO: esegue `next dev` (hot-reload) invece della build standalone.
# Il codice sorgente viene montato via bind in docker-compose.dev.yml, quindi le
# modifiche sui file dell'host si riflettono live nel container.
FROM node:22-bookworm-slim
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends openssl && rm -rf /var/lib/apt/lists/*

# Dipendenze (incluse le dev) sfruttando la cache di layer.
COPY package.json package-lock.json ./
RUN npm ci

# Client Prisma generato nell'immagine: resta nel volume anonimo node_modules a runtime.
COPY prisma ./prisma
RUN npx prisma generate

EXPOSE 3000

# Allinea lo schema del DB e avvia il dev server.
CMD ["sh", "-c", "npx prisma migrate deploy && npm run dev"]
